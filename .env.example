# Praxis — environment variables
# Copy to .env and fill in your values. Never commit .env.

# ── Splunk MCP Server ─────────────────────────────────────────────────────
# Full MCP endpoint URL — confirmed from Apps -> Splunk MCP Server -> Setup page.
# Two valid endpoints (either works):
#   http://localhost:8000/en-US/splunkd/__raw/services/mcp   (HTTP, avoids cert issues)
#   https://localhost:8089/services/mcp                       (HTTPS, management port)
SPLUNK_MCP_URL=http://localhost:8000/en-US/splunkd/__raw/services/mcp

# MCP Encrypted Token from Apps -> Splunk MCP Server -> "Create MCP Encrypted Token"
# (NOT a regular Settings -> Tokens token — use the MCP-specific one)
SPLUNK_TOKEN=

# ── Splunk REST API (used by the native SDK alert app) ────────────────────
SPLUNK_HOST=DESKTOP-V4R983R
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=

# ── Splunk AI Toolkit — Hosted Models ────────────────────────────────────
# AITK exposes models via a Splunk search command or REST endpoint.
# Set the base URL if AITK uses a separate endpoint; leave blank to use SPLUNK_MCP_URL.
AITK_BASE_URL=

# Model IDs (as registered in your AITK installation)
AITK_MODEL_SECURITY=Foundation-Sec-1.1-8B-Instruct   # for finding scoring
AITK_MODEL_GENERAL=gpt-oss-20b                         # for agent reasoning

# ── Fallback LLM (Anthropic Claude — used only if AITK is unreachable) ───
# Leave blank to disable fallback; the system will surface an error instead.
ANTHROPIC_API_KEY=

# ── Praxis backend ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
