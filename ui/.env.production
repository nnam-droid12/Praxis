# Used by `vite build` (production). Not a secret — just the API base URL.
#
# Praxis's backend (FastAPI + Splunk MCP) only binds to localhost, so this
# Vercel-hosted build talks to the backend running on the SAME machine as the
# browser. If you run `uvicorn api.main:app --port 8800` locally and open the
# deployed site in that machine's browser, Investigate/Campaign Hunter work
# against your live Splunk data. From any other machine, the UI loads but
# those tabs will show a connection error (expected for a frontend-only deploy).
VITE_API_BASE=http://localhost:8800
